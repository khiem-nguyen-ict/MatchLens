{
  "manifest_version": 3,
  "name": "MatchLens",
  "version": "1.1.0",
  "description": "LinkedIn profile optimizer and helper for efficient LinkedIn profile management.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs", "identity"],
  "host_permissions": ["*://www.linkedin.com/*", "*://gewcvyaulhlfgxsvuvqj.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.linkedin.com/*"],
      "js": ["utils.js", "supabase.js", "content.js", "linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
